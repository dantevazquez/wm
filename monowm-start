#!/bin/bash

if [ -x "$HOME/.config/monowm/autostart" ]; then
    "$HOME/.config/monowm/autostart"
fi

MONOWM_EXEC="monowm"
if ! command -v monowm >/dev/null 2>&1; then
    if [ -f "$HOME/.local/bin/monowm" ]; then
        MONOWM_EXEC="$HOME/.local/bin/monowm"
    fi
fi

if command -v lemonbar >/dev/null 2>&1; then
    exec "$MONOWM_EXEC" | lemonbar -p -f "JetBrainsMono Nerd Font:size=12"
else
    exec "$MONOWM_EXEC"
fi
