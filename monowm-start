#!/bin/bash

if [ -x "$HOME/.config/monowm/autostart" ]; then
    "$HOME/.config/monowm/autostart"
fi

MONOWM_EXEC="monowm"
if ! command -v monowm >/dev/null 2>&1; then
    if [ -f "$HOME/.local/bin/monowm" ]; then
        MONOWM_EXEC="$HOME/.local/bin/monowm"
    fi
fi

if command -v lemonbar >/dev/null 2>&1 && "$MONOWM_EXEC" --is-bar-enabled; then
    BAR_HEIGHT=$("$MONOWM_EXEC" --get-bar-height)
    BAR_FONT=$("$MONOWM_EXEC" --get-bar-font)
    exec "$MONOWM_EXEC" | lemonbar -p -g "x${BAR_HEIGHT}" -f "${BAR_FONT}"
else
    exec "$MONOWM_EXEC"
fi
